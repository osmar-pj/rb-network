[Unit]
Description=gunjop-net — interfaz web de configuración de red
After=NetworkManager.service gunjop-ap.service
Wants=NetworkManager.service

[Service]
Type=simple
WorkingDirectory=/opt/gunjop-net
ExecStart=/opt/gunjop-net/venv/bin/python -m app.main
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
